<style>
  :root {
    --black: #050505;
    --white: #f5f2ec;
    --gold: #d4a832;
    --gold-light: #f0c84a;
    --gray: #111111;
    --gray2: #1a1a1a;
    --muted: #666;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }

  body {
    background: var(--black);
    color: var(--white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.4rem 3rem;
    backdrop-filter: blur(14px);
    background: rgba(5,5,5,0.85);
    border-bottom: 1px solid rgba(212,168,50,0.1);
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.6rem;
    letter-spacing: 0.1em;
    color: var(--gold);
  }
  .logo span { color: var(--white); }

  .nav-cta {
    background: var(--gold);
    color: var(--black);
    padding: 0.6rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.3s;
  }
  .nav-cta:hover { background: var(--gold-light); }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 3rem 5rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 55% 60% at 75% 50%, rgba(212,168,50,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 30% 35% at 15% 70%, rgba(212,168,50,0.04) 0%, transparent 60%);
  }

  .hero-content { position: relative; z-index: 1; max-width: 850px; }

  .hero-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
    animation: fadeUp 0.8s ease both;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 12vw, 10rem);
    line-height: 0.88;
    letter-spacing: 0.02em;
    animation: fadeUp 0.9s 0.1s ease both;
  }

  .hero h1 .outline {
    -webkit-text-stroke: 1px rgba(245,242,236,0.35);
    color: transparent;
  }

  .hero h1 em { font-style: normal; color: var(--gold); }

  .hero-desc {
    margin-top: 2.5rem;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: var(--muted);
    max-width: 500px;
    line-height: 1.8;
    animation: fadeUp 1s 0.25s ease both;
  }

  .hero-btns {
    margin-top: 3rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeUp 1s 0.4s ease both;
  }

  .btn-primary {
    background: var(--gold);
    color: var(--black);
    border: none;
    padding: 1rem 2.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.3s, transform 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }

  .btn-ghost {
    background: transparent;
    color: var(--white);
    border: 1px solid rgba(245,242,236,0.2);
    padding: 1rem 2.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.3s, color 0.3s;
    display: inline-block;
  }
  .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }

  /* TICKER */
  .ticker {
    overflow: hidden;
    padding: 0.9rem 0;
    background: var(--gray);
    border-top: 1px solid rgba(212,168,50,0.12);
    border-bottom: 1px solid rgba(212,168,50,0.12);
  }
  .ticker-track {
    display: flex;
    gap: 3rem;
    white-space: nowrap;
    animation: ticker 25s linear infinite;
    font-size: 0.72rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ticker-track span { color: var(--gold); }

  /* SECTIONS */
  .section { padding: 7rem 3rem; position: relative; z-index: 1; }
  .section-alt { background: var(--gray); }

  .section-tag {
    font-size: 0.68rem;
    letter-spacing: 0.38em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    display: block;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .section-sub {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 540px;
    margin-bottom: 4rem;
  }

  /* HOW IT WORKS */
  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2px;
    max-width: 1100px;
  }

  .step {
    background: var(--gray2);
    padding: 3rem 2rem;
    position: relative;
    transition: background 0.3s;
  }
  .step:hover { background: #222; }
  .step::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .step:hover::before { opacity: 1; }

  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 4.5rem;
    color: rgba(212,168,50,0.1);
    line-height: 1;
    position: absolute;
    top: 1rem; right: 1.5rem;
  }

  .step-icon { font-size: 2rem; margin-bottom: 1.2rem; }

  .step h3 {
    font-size: 1rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.8rem;
    letter-spacing: 0.03em;
  }

  .step p { font-size: 0.85rem; color: var(--muted); line-height: 1.7; }

  /* WHAT YOU GET */
  .get-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1000px;
  }

  .get-grid h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .get-grid h2 em { font-style: normal; color: var(--gold); }

  .get-grid p { color: var(--muted); line-height: 1.8; font-size: 0.95rem; margin-bottom: 2rem; }

  .checklist { list-style: none; display: flex; flex-direction: column; gap: 1rem; }
  .checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    font-size: 0.9rem;
    color: var(--white);
    line-height: 1.5;
  }
  .checklist li::before { content: '✦'; color: var(--gold); font-size: 0.65rem; margin-top: 0.3rem; flex-shrink: 0; }

  /* SCALE BANNER */
