  /* FAQ */
  .faq-list { max-width: 700px; display: flex; flex-direction: column; gap: 2px; }

  .faq-item { background: var(--gray2); }

  .faq-q {
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid rgba(212,168,50,0.08);
    color: var(--white);
    padding: 1.4rem 1.5rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    font-weight: 400;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    transition: color 0.3s;
  }
  .faq-q:hover { color: var(--gold); }

  .faq-icon { color: var(--gold); font-size: 1.3rem; flex-shrink: 0; transition: transform 0.3s; }
  .faq-item.open .faq-icon { transform: rotate(45deg); }

  .faq-a {
    display: none;
    padding: 1rem 1.5rem 1.4rem;
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.75;
    border-bottom: 1px solid rgba(212,168,50,0.08);
  }
  .faq-item.open .faq-a { display: block; }

  /* CONTACT */
  .contact-inner { max-width: 620px; margin: 0 auto; text-align: center; }

  .form { display: flex; flex-direction: column; gap: 1rem; text-align: left; margin-top: 2.5rem; }

  .form input, .form select, .form textarea {
    background: var(--gray2);
    border: 1px solid rgba(255,255,255,0.07);
    color: var(--white);
    padding: 1rem 1.2rem;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.3s;
    width: 100%;
  }
  .form input:focus, .form select:focus, .form textarea:focus { border-color: var(--gold); }
  .form input::placeholder, .form textarea::placeholder { color: #444; }
  .form select option { background: var(--gray2); }
  .form textarea { resize: vertical; min-height: 110px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form .btn-primary { width: 100%; text-align: center; padding: 1.1rem; font-size: 0.88rem; margin-top: 0.5rem; }
  .form-note { text-align: center; font-size: 0.72rem; color: #444; margin-top: 0.8rem; letter-spacing: 0.05em; }

  .success-msg {
    display: none;
    margin-top: 1rem;
    padding: 1.2rem;
    border: 1px solid var(--gold);
    color: var(--gold);
    font-size: 0.88rem;
    text-align: center;
    background: rgba(212,168,50,0.06);
  }

  /* FOOTER */
  footer {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 3rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }
  .footer-center { text-align: center; font-size: 0.72rem; color: var(--muted); line-height: 1.9; }
  .footer-right { text-align: right; font-size: 0.72rem; color: var(--muted); }

  /* ANIMATIONS */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  @media (max-width: 768px) {
    nav { padding: 1.2rem 1.5rem; }
    .hero { padding: 7rem 1.5rem 4rem; }
    .section { padding: 5rem 1.5rem; }
    .get-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .scale-banner { margin: 0 1.5rem; padding: 3rem 2rem; }
    .form-row { grid-template-columns: 1fr; }
    footer { grid-template-columns: 1fr; text-align: center; }
    .footer-right { text-align: center; }
  }
</style>
</head>
