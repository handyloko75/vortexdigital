    background: var(--gray2);
    border: 1px solid rgba(212,168,50,0.2);
    margin: 0 3rem;
    padding: 4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .scale-banner::before {
    content: '';
